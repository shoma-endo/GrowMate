{
  "name": "growmate-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:types": "tsc --noEmit --watch",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "supabase:types": "supabase gen types typescript --schema public > src/types/database.types.ts",
    "db:stats": "tsx scripts/check-db-stats.ts",
    "vercel:stats": "tsx scripts/check-vercel-stats.ts",
    "active:users": "tsx scripts/check-active-users.ts",
    "knip": "knip",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify": "npm audit --audit-level=high && npm run lint && npm run test && npm run build && npm run knip",
    "verify:agent-skills": "bash scripts/verify-agent-skills.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
