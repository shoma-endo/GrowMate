    "knip": "^6.27.0",
    "postcss": "^8.5.16",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "ws": "^8.21.1"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "^8.5.16",
    "sharp": "0.35.3"
  }
