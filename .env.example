# =============================================================================
# GrowMate - AIマーケティング支援プラットフォーム
# 環境変数サンプルファイル
# =============================================================================
# 
# このファイルをコピーして `.env.local` を作成し、実際の値を設定してください。
# `.env.local` は `.gitignore` に含まれているため、Git にコミットされません。
#
# 本番環境では Vercel の環境変数設定を使用してください。
# =============================================================================

# ────────────────────────────────────────────────────────────────────────────
# Supabase 設定（必須）
# ────────────────────────────────────────────────────────────────────────────
# プロジェクト管理者から接続情報を取得してください。
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE=your_supabase_service_role_key

# ────────────────────────────────────────────────────────────────────────────
# LINE 設定（必須）
# ────────────────────────────────────────────────────────────────────────────
# プロジェクト管理者から接続情報を取得してください。
# 本番環境と開発環境でLINE Login ChannelおよびLIFFアプリを共有しています。
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
NEXT_PUBLIC_LIFF_CHANNEL_ID=your_line_channel_id
NEXT_PUBLIC_LIFF_ID=your_liff_id

# ────────────────────────────────────────────────────────────────────────────
# AI API キー（必須）
# ────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-proj-xxxxx

# ────────────────────────────────────────────────────────────────────────────
# サイト URL（必須）
# ────────────────────────────────────────────────────────────────────────────
# ローカル開発時: http://localhost:3000
# 本番環境: デプロイ先のドメインを使用（例: https://your-domain.com）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────────────────
# WordPress.com OAuth 設定（任意：WordPress連携利用時は必須）
# ────────────────────────────────────────────────────────────────────────────
# WordPress.com OAuth 連携を使用する場合のみ設定してください。
WORDPRESS_COM_CLIENT_ID=your_wordpress_com_client_id
WORDPRESS_COM_CLIENT_SECRET=your_wordpress_com_client_secret
WORDPRESS_COM_REDIRECT_URI=http://localhost:3000/api/wordpress/oauth/callback

# ────────────────────────────────────────────────────────────────────────────
# Google Search Console OAuth 設定（任意：GSC連携利用時は必須）
# ────────────────────────────────────────────────────────────────────────────
# Google Search Console 連携を使用する場合のみ設定してください。
# 詳細は README.md の「5. Google Search Console の設定」セクションを参照してください。
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# ローカル開発時
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=http://localhost:3000/api/gsc/oauth/callback
# 本番環境
# GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=https://your-domain.com/api/gsc/oauth/callback

# ────────────────────────────────────────────────────────────────────────────
# Cookie Secret（任意）
# ────────────────────────────────────────────────────────────────────────────
# WordPress / Google Search Console OAuth のセキュアな Cookie 管理用シークレット
# 生成方法: openssl rand -hex 32
COOKIE_SECRET=your_random_32_char_secret_key

# ────────────────────────────────────────────────────────────────────────────
# Cron Secret（任意：GSC評価バッチ利用時は必須）
# ────────────────────────────────────────────────────────────────────────────
# GSC 評価バッチ実行用の共有シークレット（Bearer 認証）
# GitHub Actions で同じ値を CRON_SECRET シークレットとして設定してください
# 生成方法: openssl rand -hex 32
CRON_SECRET=your_random_32_char_secret_key

# ────────────────────────────────────────────────────────────────────────────
# Google Ads OAuth 設定（任意：Google Ads連携利用時は必須）
# ────────────────────────────────────────────────────────────────────────────
# Google Ads 連携を使用する場合のみ設定してください。
# 注意: 現在は管理者のみ利用可能です（審査完了まで）
# Google Ads API 開発者トークン（MCCアカウントの管理者が発行）
# Google Ads管理画面 > 管理者 > APIセンター から取得
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
# ローカル開発時
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/google-ads/oauth/callback
# 本番環境
# GOOGLE_ADS_REDIRECT_URI=https://your-domain.com/api/google-ads/oauth/callback
